{
  "name": "worldmind",
  "version": "0.1.0",
  "private": true,
  "description": "WorldMind v0.5 — TypeScript runtime migration foundation, typed contracts and CLI validation gates.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/cli/simulate.js --days 7 --dashboard",
    "simulate": "node src/cli/simulate.js --days 7",
    "dashboard": "node src/cli/simulate.js --days 7 --dashboard",
    "saves:list": "node src/cli/simulate.js --list-saves",
    "saves:branches": "node src/cli/simulate.js --list-branches",
    "saves:diff": "node src/cli/simulate.js --compare-snapshots",
    "sim:from-snapshot": "node src/cli/simulate.js --continue-from-snapshot",
    "sim:branch": "node src/cli/simulate.js --create-branch",
    "validate:scenario": "node src/cli/validate.js scenario",
    "validate:snapshot": "node src/cli/validate.js snapshot",
    "validate:diff": "node src/cli/validate.js diff",
    "validate:branch": "node src/cli/validate.js branch",
    "validate:action": "node src/cli/validate.js action",
    "validate:dashboard": "node src/cli/validate.js dashboard",
    "validate:risk": "node src/cli/validate.js risk",
    "validate:event-log": "node src/cli/validate.js event-log",
    "diff:canonical": "node src/cli/diff-checker.js canonical --scenario scenarios/new-aarhus-district-01.json",
    "diff:event-log": "node src/cli/diff-checker.js event-log",
    "ci:gate": "npm run typecheck && npm test && npm run check && node src/cli/validate.js scenario scenarios/new-aarhus-district-01.json && node src/cli/validate.js branch scenarios/branch-v06-canonical.json && node src/cli/validate.js dashboard static-dashboard && node src/cli/validate.js action && node src/cli/validate.js risk && node src/cli/validate.js event-log && node src/cli/diff-checker.js canonical --scenario scenarios/new-aarhus-district-01.json && node src/cli/diff-checker.js event-log",
    "test": "node --test",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "check": "npm run typecheck && node src/cli/simulate.js --days 7 --assert"
  },
  "keywords": [
    "ai-agents",
    "simulation",
    "emergent-story",
    "game-engine",
    "worldmind",
    "typescript"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "better-sqlite3": "^12.11.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "typescript": "^5.5.4"
  }
}
