{
  "name": "worldmind",
  "version": "0.1.0",
  "private": true,
  "description": "WorldMind v1.0-rc16 \u2014 procedural textures (6 materials) + PBR GLB assembler + ci:gate recursion fix",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/cli/simulate.js --days 7 --dashboard",
    "simulate": "node src/cli/simulate.js --days 7",
    "dashboard": "node src/cli/simulate.js --days 7 --dashboard",
    "saves:list": "node src/cli/saves.js list",
    "saves:branches": "node src/cli/simulate.js --list-branches",
    "saves:diff": "node src/cli/saves.js diff",
    "sim:from-snapshot": "node src/cli/simulate.js --continue-from-snapshot",
    "sim:branch": "node src/cli/simulate.js --create-branch",
    "validate:scenario": "node src/cli/validate.js scenario",
    "validate:snapshot": "node src/cli/validate.js snapshot",
    "validate:diff": "node src/cli/validate.js diff",
    "validate:branch": "node src/cli/validate.js branch",
    "validate:action": "node src/cli/validate.js action",
    "validate:dashboard": "node src/cli/validate.js dashboard",
    "validate:risk": "node src/cli/validate.js risk",
    "validate:risk:strict": "node src/cli/validate.js risk --strict",
    "validate:state": "node src/cli/validate.js state",
    "validate:event-log": "node src/cli/validate-event-log.js",
    "validate:event-log:strict": "node src/cli/validate-event-log.js --strict",
    "saves": "node src/cli/saves.js",
    "saves:timeline": "node src/cli/saves.js timeline",
    "diff:canonical": "node src/cli/diff-checker.js canonical --scenario scenarios/new-aarhus-district-01.json",
    "diff:event-log": "node src/cli/diff-checker.js event-log",
    "play": "node src/cli/play.js",
    "demo:play": "node src/cli/demo-play.js",
    "demo:guided-play": "node src/cli/demo-guided-play.js",
    "play:web": "node src/cli/play-web.js",
    "play:server": "node src/cli/play-server.js",
    "bake:3d-models": "npm --prefix ../worldmind-site run bake:3d-models",
    "validate:leno": "node src/cli/validate-leno.js",
    "validate:web-play": "node src/cli/validate-web-play.js",
    "validate:play-api": "node src/cli/validate-play-api.js",
    "verify:production-play": "node src/cli/verify-production-play.js",
    "validate:game-foundation": "node src/cli/validate-game-foundation.js",
    "validate:play-server": "node src/cli/validate-saves-ui.js",
    "validate:saves-ui": "node src/cli/validate-saves-ui.js",
    "validate:district-ui": "node src/cli/validate-district-ui.js",
    "validate:creator": "node src/cli/creator.js validate",
    "validate:content-pack-authoring": "node src/cli/validate-content-pack-authoring.js",
    "validate:scenario-loader": "node src/cli/validate-scenario-loader.js",
    "validate:scenario-schema": "node src/cli/validate-scenario-schema.js",
    "validate:episode-loader": "node src/cli/validate-episode-loader.js",
    "assets:build": "node tools/wm-assets.js build --out=assets/models",
    "assets:validate": "node tools/wm-assets.js validate --out=assets/models",
    "textures:build": "node tools/wm-textures.js --material=wood --out=assets/textures/wood.png",
    "creator": "node src/cli/creator.js",
    "creator:scenario": "node src/cli/creator.js scenario",
    "ci:gate": "npm run typecheck && npm run check && node src/cli/validate.js scenario scenarios/new-aarhus-district-01.json && node src/cli/validate.js branch scenarios/branch-v06-canonical.json && node src/cli/validate.js dashboard static-dashboard && node src/cli/validate.js action && node src/cli/validate.js risk --strict && node src/cli/validate.js state && node src/cli/validate-event-log.js && node src/cli/validate-leno.js && node src/cli/diff-checker.js canonical --scenario scenarios/new-aarhus-district-01.json && node src/cli/diff-checker.js event-log && node src/cli/demo-play.js && node src/cli/validate-game-foundation.js && node src/cli/play-web.js && node src/cli/validate-web-play.js && node src/cli/validate-saves-ui.js --skip-server && node src/cli/validate-district-ui.js --skip-server && node src/cli/creator.js validate scenarios/creator-example-district.json && node src/cli/validate-content-pack-authoring.js && node src/cli/validate-scenario-loader.js && node src/cli/validate-scenario-schema.js && node src/cli/validate-episode-loader.js && node tools/wm-assets.js validate --out=assets/models && node tools/wm-textures.js --material=wood --out=assets/textures/wood.png",
    "test": "node --test --test-skip-pattern=\"v0.6|v0.7|v0.8|v1.0 typed\"",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "check": "npm run typecheck && node src/cli/simulate.js --days 7 --assert",
    "audit:worldmind": "node src/cli/audit-worldmind.js",
    "release:verify": "node src/cli/release-verify.js",
    "test:all": "node --test"
  },
  "keywords": [
    "ai-agents",
    "simulation",
    "emergent-story",
    "game-engine",
    "worldmind",
    "typescript"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "better-sqlite3": "^12.11.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "typescript": "^5.5.4"
  }
}